\newcommand{\gxuSpecialChapterTitle}[1]{%
  \par\begingroup
    \centering
    {\sanhao\heiti #1\par}
  \endgroup
  \vspace{\baselineskip}
}

\makeatletter
\newcommand{\gxuIndentAfterTitle}{%
  \@afterindenttrue
  \@afterheading
}
\makeatother

\ExplSyntaxOn
\cs_new_protected:Npn \gxu_format_cn_keywords:n #1
  {
    \group_begin:
      \tl_set:Nn \l_tmpa_tl {#1}
      \regex_replace_all:nnN { \s*[；;，,、]\s* } {|} \l_tmpa_tl
      \regex_replace_once:nnN { [|；;，,、。．.]+\s*\Z } {} \l_tmpa_tl
      \seq_set_split:NnV \l_tmpa_seq {|} \l_tmpa_tl
      \seq_clear:N \l_tmpb_seq
      \seq_map_inline:Nn \l_tmpa_seq
        {
          \tl_set:Nx \l_tmpb_tl { \tl_trim_spaces:n {##1} }
          \tl_if_blank:VTF \l_tmpb_tl
            {}
            { \seq_put_right:NV \l_tmpb_seq \l_tmpb_tl }
        }
      \seq_use:Nn \l_tmpb_seq { \hspace{1em} }
    \group_end:
  }
\cs_new_eq:NN \gxuFormatCnKeywords \gxu_format_cn_keywords:n
\ExplSyntaxOff

