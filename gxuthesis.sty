\ExplSyntaxOn
\cs_new_protected:Npn \gxu_defense_date_zero:
  {
    \kern0.03em
    \raisebox{0.03em}
      {{\CJKfontspec{SimSun}\fontsize{15.8pt}{18pt}\selectfont ○}}
    \kern0.03em
  }
\cs_new_protected:Npn \gxu_render_date_chunk:n #1
  {
    \tl_set:Nn \l_tmpa_tl {#1}
    \tl_replace_all:Nnn \l_tmpa_tl {〇} { \gxu_defense_date_zero: }
    \tl_replace_all:Nnn \l_tmpa_tl {○} { \gxu_defense_date_zero: }
    \tl_use:N \l_tmpa_tl
  }
\cs_new_protected:Npn \gxuRenderDateChunk #1
  { \gxu_render_date_chunk:n {#1} }
\ExplSyntaxOff

\newcommand{\gxuDefenseDateGapGlyph}{\hspace{0.5em}}
\makeatletter
\newcommand{\gxuRenderDefenseDate}[1]{%
  \begingroup
  \edef\gxu@datecompact{\zap@space#1 \@empty}%
  \expandafter\gxu@renderDefenseDate\gxu@datecompact\@nil
  \endgroup
}
\def\gxu@renderDefenseDate#1年#2月#3日#4\@nil{%
  \gxuRenderDateChunk{#1}%
  \gxuDefenseDateGapGlyph 年\gxuDefenseDateGapGlyph
  \gxuRenderDateChunk{#2}%
  \gxuDefenseDateGapGlyph 月\gxuDefenseDateGapGlyph
  \gxuRenderDateChunk{#3}%
  \gxuDefenseDateGapGlyph 日%
}
\makeatother

